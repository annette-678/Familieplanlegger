                    const rLabel = rMin===0?"Ingen varsel":rMin<60?`${rMin} min før`:`${rMin/60} time${rMin>60?"r":""} før`;
                    return (
                      <div key={ev.id} style={{ background:"white",borderRadius:12,padding:"12px",marginBottom:8,borderLeft:`4px solid ${member.color}`,boxShadow:"0 1px 4px rgba(0,0,0,0.05)" }}>
                        <div style={{ display:"flex",alignItems:"flex-start",gap:10 }}>
                          <div style={{ fontSize:20,marginTop:1 }}>{cat.icon}</div>
                          <div style={{ flex:1,minWidth:0 }}>
                            <div style={{ fontWeight:700,fontSize:15 }}>{ev.title}</div>
                            <div style={{ fontSize:11,color:"#999",marginTop:2 }}>
                              {ev.time&&<span style={{ fontWeight:600,color:"#555" }}>{ev.time} · </span>}
                              {member.emoji} {member.name} · {cat.label}
                            </div>
                            {ev.time&&<div style={{ fontSize:11,color:"#bbb",marginTop:2 }}>🔔 {rLabel}</div>}
                            {ev.note&&<div style={{ fontSize:12,color:"#666",marginTop:4,fontStyle:"italic" }}>{ev.note}</div>}
                          </div>
                          <div style={{ display:"flex",gap:4,flexShrink:0 }}>
                            <button onClick={()=>openEdit(ev,selected)} className="tap" style={{ fontSize:15,opacity:.4,padding:4 }}>✏️</button>
                            <button onClick={()=>deleteEvent(selected,ev.id)} className="tap" style={{ fontSize:15,opacity:.4,padding:4 }}>🗑️</button>
                          </div>
                        </div>
                      </div>
                    );
                  })}
            </div>
          </div>
        );
      })()}

      {/* ── Add/edit sheet ── */}
      {modal==="add"&&selected&&(
        <div style={{ position:"fixed",inset:0,zIndex:40,display:"flex",flexDirection:"column",justifyContent:"flex-end" }} onClick={()=>setModal("detail")}>
          <div style={{ background:"rgba(0,0,0,0.5)",position:"absolute",inset:0 }} />
          <div className="slide-up" onClick={e=>e.stopPropagation()} style={{ background:"white",borderRadius:"20px 20px 0 0",padding:"22px 16px 44px",position:"relative" }}>
            <div style={{ fontFamily:"'Fraunces',serif",fontSize:17,fontWeight:700,marginBottom:14 }}>
              {editId?"Rediger hendelse":`${selected.getDate()}. ${MONTHS_NO[selected.getMonth()]}`}
            </div>

            <input value={form.title} onChange={e=>setForm(f=>({...f,title:e.target.value}))}
              placeholder="Hva skjer? *" autoFocus style={{ width:"100%",padding:"12px 13px",borderRadius:10,border:"1.5px solid #eee",fontSize:15,fontWeight:500,background:"#fafafa",outline:"none",marginBottom:10 }} />

            <div style={{ display:"grid",gridTemplateColumns:"1fr 1fr",gap:8,marginBottom:10 }}>
              <input type="time" value={form.time} onChange={e=>setForm(f=>({...f,time:e.target.value}))}
                style={{ padding:"10px 11px",borderRadius:10,border:"1.5px solid #eee",fontSize:14,background:"#fafafa",outline:"none" }} />
              <select value={form.member} onChange={e=>setForm(f=>({...f,member:e.target.value}))}
                style={{ padding:"10px 11px",borderRadius:10,border:"1.5px solid #eee",fontSize:13,background:"#fafafa",outline:"none" }}>
                {FAMILY_MEMBERS.map(m=><option key={m.id} value={m.id}>{m.emoji} {m.name}</option>)}
              </select>
            </div>

            <div style={{ display:"flex",gap:5,flexWrap:"wrap",marginBottom:10 }}>
              {CATEGORIES.map(cat=>(
                <button key={cat.id} onClick={()=>setForm(f=>({...f,category:cat.id}))} style={{
                  padding:"5px 11px",borderRadius:14,fontSize:11,fontWeight:600,
                  background:form.category===cat.id?"#1a1a1a":"#f0ede8",
                  color:form.category===cat.id?"white":"#666",transition:"all .12s",
                }}>{cat.icon} {cat.label}</button>
              ))}
            </div>

            {/* Reminder selector — vises kun hvis klokkeslett er satt */}
            {form.time && (
              <div style={{ marginBottom:10 }}>
                <div style={{ fontSize:11,fontWeight:600,color:"#aaa",marginBottom:5,textTransform:"uppercase",letterSpacing:.8 }}>🔔 Påminnelse</div>
                <div style={{ display:"flex",gap:5,flexWrap:"wrap" }}>
                  {REMINDER_OPTIONS.map(opt=>(
                    <button key={opt.value} onClick={()=>setForm(f=>({...f,reminderMinutes:opt.value}))} style={{
                      padding:"5px 11px",borderRadius:14,fontSize:11,fontWeight:600,
                      background:form.reminderMinutes===opt.value?"#1a1a1a":"#f0ede8",
                      color:form.reminderMinutes===opt.value?"white":"#666",transition:"all .12s",
                    }}>{opt.label}</button>
                  ))}
                </div>
              </div>
            )}

            <textarea value={form.note} onChange={e=>setForm(f=>({...f,note:e.target.value}))}
              placeholder="Notat (valgfritt)" rows={2} style={{ width:"100%",padding:"10px 13px",borderRadius:10,border:"1.5px solid #eee",fontSize:13,background:"#fafafa",resize:"none",outline:"none",marginBottom:14 }} />

            <button onClick={saveEvent} disabled={!form.title.trim()} style={{
              width:"100%",padding:"13px",borderRadius:12,
              background:form.title.trim()?"#e07b5a":"#ddd",
              color:"white",fontSize:15,fontWeight:700,transition:"background .2s",
            }}>{editId?"Lagre endringer":"Legg til"}</button>
          </div>
        </div>
      )}

      {/* Demo banner */}
      {fbStatus==="demo"&&(
        <div style={{ position:"fixed",bottom:90,left:12,right:12,zIndex:15,background:"#1a1a1a",color:"white",borderRadius:14,padding:"12px 14px",fontSize:12,boxShadow:"0 4px 20px rgba(0,0,0,0.2)" }}>
          <div style={{ fontWeight:700,marginBottom:4 }}>⚡ Demo-modus</div>
          <div style={{ opacity:.6,lineHeight:1.5 }}>Bytt ut Firebase-konfigen for synkronisering og push-varsler.</div>
        </div>
      )}
    </div>
  );
}
