function dateKey(d) {
  return `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,"0")}-${String(d.getDate()).padStart(2,"0")}`;
}
function addDays(d, n) { const r = new Date(d); r.setDate(r.getDate()+n); return r; }
function isSameDay(a,b) { return a.getFullYear()===b.getFullYear()&&a.getMonth()===b.getMonth()&&a.getDate()===b.getDate(); }
function getMonthDays(year, month) {
  const first = (new Date(year,month,1).getDay()+6)%7;
  const total = new Date(year,month+1,0).getDate();
  const days = [];
  for(let i=0;i<first;i++) days.push(null);
  for(let d=1;d<=total;d++) days.push(d);
  return days;
}

// ─── Firebase ─────────────────────────────────────────────────────────────────
let db=null, auth=null, messaging=null, currentUser=null, firestoreReady=false;
let unsubscribe=null;

async function initFirebase(setUser, setEvents, setFbStatus, setNotifStatus) {
  try {
    setFbStatus("connecting");
    await Promise.all([
      loadScript("https://www.gstatic.com/firebasejs/10.12.0/firebase-app-compat.js"),
      loadScript("https://www.gstatic.com/firebasejs/10.12.0/firebase-firestore-compat.js"),
      loadScript("https://www.gstatic.com/firebasejs/10.12.0/firebase-auth-compat.js"),
      loadScript("https://www.gstatic.com/firebasejs/10.12.0/firebase-messaging-compat.js"),
    ]);
    if (!window.firebase.apps.length) window.firebase.initializeApp(FIREBASE_CONFIG);
    db        = window.firebase.firestore();
    auth      = window.firebase.auth();
    messaging = window.firebase.messaging();
    firestoreReady = true;

    auth.onAuthStateChanged(async user => {
      currentUser = user;
      setUser(user);
      if (user) {
        setFbStatus("online");
        subscribeEvents(setEvents);
        await registerPushToken(user, setNotifStatus);
      } else {
        setFbStatus("loggedout");
      }
    });
  } catch(e) {
    console.error("Firebase init:", e);
    setFbStatus("error");
  }
}

function loadScript(src) {
  return new Promise((res,rej) => {
    if (document.querySelector(`script[src="${src}"]`)) { res(); return; }
    const s = document.createElement("script");
    s.src=src; s.onload=res; s.onerror=rej;
    document.head.appendChild(s);
  });
}

function subscribeEvents(setEvents) {
  if (!db||!currentUser) return;
  if (unsubscribe) unsubscribe();
  unsubscribe = db.collection("familiekalender").doc("events")
    .onSnapshot(snap => { setEvents(snap.exists ? snap.data().data||{} : {}); },
    err => console.error("Firestore:", err));
}

async function persistEvents(events) {
  if (!db||!currentUser||!firestoreReady) return;
  try { await db.collection("familiekalender").doc("events").set({ data: events }); }
  catch(e) { console.error("Firestore write:", e); }
}

async function registerPushToken(user, setNotifStatus) {
  if (!messaging || !("Notification" in window)) return;

  // Register service worker first
  let swReg;
  try {
    swReg = await navigator.serviceWorker.register("/firebase-messaging-sw.js");
  } catch(e) {
    console.warn("SW register failed:", e);
    return;
  }

  const permission = Notification.permission;
  if (permission === "denied") { setNotifStatus("denied"); return; }
  if (permission === "default") { setNotifStatus("prompt"); return; }

  // Already granted — get token
  try {
    const token = await messaging.getToken({ vapidKey: VAPID_KEY, serviceWorkerRegistration: swReg });
    if (token) {
      await saveToken(user.uid, token);
      setNotifStatus("granted");
    }
  } catch(e) {
    console.warn("FCM token:", e);
  }
}

async function requestNotificationPermission(user, setNotifStatus) {
  if (!messaging) return;
  try {
    const permission = await Notification.requestPermission();
    if (permission === "granted") {
      await registerPushToken(user, setNotifStatus);
    } else {
      setNotifStatus("denied");
    }
  } catch(e) { console.error("Permission:", e); }
}

async function saveToken(uid, token) {
  if (!db) return;
  const deviceId = btoa(navigator.userAgent).slice(0,16);
  try {
    await db.collection("familiekalender").doc("fcmTokens").set(
      { tokens: { [uid]: { [deviceId]: token } } },
      { merge: true }
    );
  } catch(e) { console.error("Save token:", e); }
}

async function signInGoogle() {
  if (!auth) return;
  try { await auth.signInWithPopup(new window.firebase.auth.GoogleAuthProvider()); }
  catch(e) { console.error("Sign in:", e); }
}
async function signOut() {
  if (!auth) return;
  try { await auth.signOut(); }
  catch(e) { console.error("Sign out:", e); }
}

